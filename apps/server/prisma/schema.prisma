// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  guest
  registered
}

model User {
  id           String    @id @default(uuid())
  type         UserType
  username     String
  email        String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastLoginAt  DateTime?
  wonGames     Game[]    @relation("GameWinner")
  createdGames Game[]    @relation("GameCreator")
  passkeys     Passkey[]

  @@index([deletedAt, createdAt])
}

model Passkey {
  id             String   @id // credential ID, base64url-encoded
  publicKey      Bytes // COSE public key
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webAuthnUserId String // WebAuthn user handle, base64url-encoded
  counter        BigInt   @default(0) // signature counter for replay protection
  deviceType     String // "singleDevice" | "multiDevice"
  backedUp       Boolean  @default(false)
  transports     String[] // e.g. ["internal", "hybrid"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

enum GameStatus {
  lobby
  countdown
  active
  finished
}

model Game {
  id              String     @id @default(uuid())
  creator         User       @relation("GameCreator", fields: [createdBy], references: [id])
  createdBy       String
  invitedPlayerId String?
  players         Json
  currentTurn     String
  globalValue     Int
  status          GameStatus
  winner          User?      @relation("GameWinner", fields: [winnerId], references: [id])
  winnerId        String?
  version         Int
  moves           Move[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
}

model Move {
  id         String   @id @default(uuid())
  game       Game     @relation(fields: [gameId], references: [id])
  gameId     String
  playerId   String
  value      Int
  moveNumber Int
  createdAt  DateTime @default(now())

  @@index([gameId])
}
