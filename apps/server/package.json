{
  "name": "server",
  "version": "0.1.0",
  "description": "",
  "private": true,
  "main": "dist/src/server.js",
  "type": "module",
  "engines": {
    "node": "24",
    "pnpm": "10"
  },
  "exports": {
    "./types": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "dev": "pnpm build & tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "clean": "rm -rf node_modules && rm -rf dist",
    "format": "biome format --write",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "postinstall": "SKIP_ENV_VALIDATION=1 pnpm db:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/redis": "^7.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@simplewebauthn/server": "^13.2.3",
    "@trpc/server": "^11.9.0",
    "close-with-grace": "^2.5.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.2",
    "ioredis": "^5.9.2",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "remeda": "^2.33.4",
    "superjson": "^2.2.6",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@repo/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "^11.12.0",
    "@testcontainers/redis": "^11.12.0",
    "@types/node": "^24.10.9",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
